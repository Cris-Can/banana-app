rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES AYUDA ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isCreator(event) {
      return isSignedIn() && request.auth.uid == event.creatorId;
    }
    // Campos que NADIE puede editar desde el cliente (solo Cloud Functions con admin SDK)
    function protectedFields() {
      return ['admin', 'isFounder', 'isGold', 'subscriptionType', 'eventsRequestedCount', 'ratingSum', 'ratingCount', 'isVerified', 'isBoosted', 'boostExpiry', 'boostUntil', 'boostedAt', 'boostedBy', 'identityVerified'];
    }
    
    // --- EVENTOS ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && request.resource.data.creatorId == request.auth.uid 
                    && request.resource.data.approvedParticipants == [request.auth.uid];
      
      allow update: if isCreator(resource.data) 
                    || (isSignedIn() 
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['pendingRequests']));
                    
      allow delete: if isCreator(resource.data);
      
      match /feed/{postId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/events/$(eventId)).data.approvedParticipants ||
          request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.creatorId
        );
      }
    }

    // --- RATINGS ---
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
    }

    // --- USUARIOS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow update: if isSignedIn() && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(protectedFields());
      
      // Admin: puede editar cualquier usuario, incluidos campos protegidos
      allow update: if isSignedIn()
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
      
      match /profile_views/{visitorId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && request.auth.uid == visitorId;
      }
    }

    // --- NOTIFICACIONES ---
    match /notifications/{id} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid; 
    }

    // --- ATTENDANCE RECORDS (Stats) ---
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- CONVERSACIONES (Chats) ---
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow delete: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update: if isSignedIn() 
                && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                && request.auth.uid == request.resource.data.senderId;
        allow delete: if isSignedIn() 
                && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                && request.auth.uid == resource.data.senderId;
      }
    } 

    // --- CHECK-INS (GPS) ---
    match /event_checkins/{checkInId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.approvedParticipants ||
        request.auth.uid == get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.creatorId
      );
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    // --- REPORTES ---
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update: if false;
    }

    // --- CONFIG GLOBAL (Stats User Count) ---
    match /config/stats {
      allow read: if isSignedIn(); 
      allow update, create: if false;
    }

    // --- CÓDIGOS DE INVITACIÓN ---
    match /invitation_codes/{codeId} {
      allow create, read: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    // --- FRIEND REQUESTS ---
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId
      );
      allow create, update, delete: if false;
    }

    // --- FRIENDSHIPS (modelo de doble documento) ---
    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow create, update, delete: if false;
    }

    // --- ENCOUNTERS (NFC/GPS check-ins entre usuarios) ---
    match /encounters/{encounterId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId1 ||
        request.auth.uid == resource.data.userId2
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId1 == request.auth.uid ||
        request.resource.data.userId2 == request.auth.uid
      );
      allow update, delete: if false;
    }

    // --- RATING SKIPS ---
    match /rating_skips/{skipId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
  }
}
