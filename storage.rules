rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── PORTADAS DE EVENTOS ──
    // Lectura pública, escritura solo autenticados (max 5MB, solo imágenes)
    match /events_covers/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── FOTOS DE PERFIL (ruta legacy) ──
    // TODO: Migrar a /profileImages/ y eliminar esta regla legacy
    // Solo el dueño puede escribir (max 5MB, solo imágenes)
    match /users/{userId}/photos/{photoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── FOTOS DE PERFIL (ruta nueva) ──
    // Solo el dueño puede escribir, cualquier autenticado puede leer
    match /profileImages/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── FOTOS DEL FEED/MURO DE EVENTOS (RUTA REAL del código) ──
    // Coincide con FeedRepository.kt: events_feed/{eventId}/{postId}.jpg
    match /events_feed/{eventId}/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── FOTOS DEL FEED/MURO DE EVENTOS (ruta alternativa) ──
    // Cualquier autenticado puede leer/escribir (validación de participación en backend)
    match /eventPhotos/{eventId}/{postId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── UPLOADS TEMPORALES ──
    // Solo el dueño puede leer y escribir
    match /tempUploads/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // ── AUDIOS DE CONVERSACIONES ──
    // Solo los participantes de la conversación pueden leer y escribir (max 10MB)
    match /conversations/{conversationId}/audio/{audioId} {
      allow read: if request.auth != null
                  && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants;
      allow write: if request.auth != null
                   && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*|application/octet-stream');
    }

    // ── FALLBACK: DENY ALL ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
