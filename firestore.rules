rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES AYUDA ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isCreator(event) {
      return isSignedIn() && request.auth.uid == event.creatorId;
    }
    // Campos que NADIE puede editar desde el cliente (solo Cloud Functions con admin SDK)
    function protectedFields() {
      return ['isFounder', 'isGold', 'subscriptionType', 'eventsRequestedCount', 'ratingSum', 'ratingCount'];
    }
    
    // --- EVENTOS ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && request.resource.data.creatorId == request.auth.uid 
                    && request.resource.data.approvedParticipants == [request.auth.uid];
      
      // Creador: puede editar todo del evento
      // No-creador: solo puede agregar/quitar su propia solicitud en pendingRequests              
      allow update: if isCreator(resource.data) 
                    || (isSignedIn() 
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['pendingRequests', 'approvedParticipants']));
                    
      allow delete: if isCreator(resource.data);
      
      // Feed interno del evento. Solo participantes aprobados o el creador.
      match /feed/{postId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/events/$(eventId)).data.approvedParticipants ||
          request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.creatorId
        );
      }
    }

    // --- RATINGS ---
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
    }

    // --- USUARIOS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Dueño: puede actualizar su perfil, EXCEPTO campos protegidos del sistema
      allow update: if isSignedIn() && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(protectedFields());
      
      // Otros usuarios: solo pueden modificar campos de amistad
      allow update: if isSignedIn() && request.auth.uid != userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['friendRequestsReceived', 'friends', 'friendRequestsSent']);
    }

    // --- NOTIFICACIONES ---
    match /notifications/{id} {
      // Leer y eliminar solo el destinatario
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      // Crear: el emisor debe ser el auth user, y solo puede enviar tipos permitidos
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid; 
    }

    // --- ATTENDANCE RECORDS (Stats) ---
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- CONVERSACIONES (Chats) ---
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    } 

    // --- CHECK-INS (GPS) ---
    match /event_checkins/{checkInId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // --- REPORTES ---
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update: if false; // Privado para admins
    }

    // --- CONFIG GLOBAL (Stats User Count) ---
    match /config/stats {
      allow read: if isSignedIn(); 
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userCount'])
                    && (request.resource.data.userCount == resource.data.userCount + 1 
                        || request.resource.data.userCount == resource.data.userCount);
      allow create: if isSignedIn() && request.resource.data.keys().hasOnly(['userCount']) && request.resource.data.userCount is number;
    }
    
  }
}
