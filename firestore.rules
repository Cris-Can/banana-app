rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES AYUDA ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isCreator(event) {
      return isSignedIn() && request.auth.uid == event.creatorId;
    }
    
    // --- EVENTOS ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      // Permitir crear si está logueado y se asigna como creador y participante
      allow create: if isSignedIn() 
                    && request.resource.data.creatorId == request.auth.uid 
                    && request.resource.data.approvedParticipants == [request.auth.uid];
                    
      // Actualizar: Creador puede todo. 
      // Otros (unirse): solo pueden modificar arrays de solicitudes si la lógica de cliente lo requiere, 
      // pero idealmente esto se maneja con la lógica robusta de arrayUnion. 
      // Para MVP permitimos update si es el creador O si afecta solo a pendingRequests (solicitar unirse)
      allow update: if isCreator(resource.data) 
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests', 'approvedParticipants']));
                    
      allow delete: if isCreator(resource.data);
      
      // Feed interno del evento
      match /feed/{postId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- RATINGS ---
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
    }

    // --- USUARIOS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Actualizar: Dueño total. Otros pueden escribir SOLO en campos de amistad
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendRequestsReceived', 'friends', 'friendRequestsSent'])
      );
    }

    // --- NOTIFICACIONES ---
    match /notifications/{id} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow write: if isSignedIn(); // Permitir enviar notificaciones (cliente a cliente en MVP)
    }

    // --- ATTENDANCE RECORDS (Stats) ---
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- CONVERSACIONES (Chats) ---
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    } 

    // --- CHECK-INS (GPS) ---
    match /event_checkins/{checkInId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // --- REPORTES (Nuevo) ---
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if false; // Privado para admins
    }

    // --- CONFIG GLOBAL (Stats User Count) ---
    match /config/stats {
      allow read, write: if isSignedIn(); 
    }
    
  }
}
